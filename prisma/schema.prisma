generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ban_appeals {
  id              Int       @id @default(autoincrement())
  user_id         String
  appeal_guild_id String
  source_guild_id String
  appeal_reason   String
  ban_reason      String?
  status          String?   @default("open")
  reviewed_by     String?
  decision_reason String?
  channel_id      String?
  message_id      String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
}

model confessions {
  id           Int       @id @default(autoincrement())
  text         String
  is_anonymous Boolean
  author_id    String
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  guild_id     String?
}

model kmk_posts {
  id             Int       @id @default(autoincrement())
  text           String
  image_url      String?
  scheduled_time DateTime? @db.Timestamp(6)
  author_id      String
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  image_url_2    String?
  image_url_3    String?
  guild_id       String?
}

model mod_logs {
  id           Int       @id @default(autoincrement())
  action       String
  target_id    String
  moderator_id String
  reason       String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  guild_id     String?
}

model server_settings {
  guild_id              String    @id
  log_channel_id        String?
  mod_role_id           String?
  confession_channel_id String?
  created_at            DateTime? @default(now()) @db.Timestamp(6)
  updated_at            DateTime? @default(now()) @db.Timestamp(6)
  language              String?   @default("en")
  source_guild_id       String?
  appeal_invite_url     String?
  main_invite_url       String?
}

model users {
  id         String    @id
  username   String?
  warnings   Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  guild_id   String?
}
